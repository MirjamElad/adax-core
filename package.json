{
  "name": "adax-core",
  "version": "0.3.4",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "description": "adax core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MirjamElad/adax-core.git"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "author": "Mirjam Elad",
  "license": "private for now",
  "sideEffects": false,
  "scripts": {
    "test": "npx jest",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
