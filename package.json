    "dev": "tsup src/index.ts --format esm,cjs --watch --dts",
    "pack:local": "npm pack",
    "publish": "npm run build && npm publish"
  },
  "keywords": [
    "micro frontends",
    "state management"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.5.0",
    "typescript": "^5.5.4",
    "vite": "^7.0.6"
  }
}
